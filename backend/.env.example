# ── Database (session pooler — port 5432 = pinned connection) ─────
POSTGRES_USER=postgres.<your-project-ref>
POSTGRES_PASSWORD=changethis
POSTGRES_SERVER=aws-1-ap-southeast-2.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ── Connection Pool ───────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
COOKIE_SECURE=false
